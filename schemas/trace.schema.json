{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prooftask.dev/schemas/trace.schema.json",
  "title": "ProofTask Verification Trace",
  "type": "object",
  "required": [
    "trace_id",
    "task_id",
    "status",
    "created_at",
    "updated_at",
    "task",
    "proof",
    "events"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "description": "Stable verification trace identifier."
    },
    "task_id": {
      "type": "string",
      "description": "Task identifier shared by the task, proof, and trace."
    },
    "status": {
      "type": "string",
      "enum": ["submitted", "verified", "rejected"],
      "description": "Current verification status of the trace."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "task": {
      "type": "object",
      "description": "Embedded task snapshot at trace time."
    },
    "proof": {
      "type": "object",
      "description": "Embedded proof submission snapshot."
    },
    "verification": {
      "type": "object",
      "required": ["decision", "verifier", "verified_at"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["verified", "rejected"]
        },
        "verifier": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_type", "status", "at", "actor"],
        "properties": {
          "event_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "actor": {
            "type": "string"
          },
          "proof_id": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["verified", "rejected"]
          }
        }
      },
      "then": {
        "required": ["verification"]
      }
    }
  ],
  "additionalProperties": false
}
